# ---- Server ----
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ---- Database (Prisma / PostgreSQL) ----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vms_db?schema=public"

# ---- JWT ----
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Cookies ----
COOKIE_SECRET=replace_with_a_random_string

# ---- Email (Nodemailer / SMTP or Resend) ----
# If left blank, the system falls back to a "console" transport that logs
# emails instead of sending them — useful for local development.
EMAIL_PROVIDER=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
RESEND_API_KEY=
EMAIL_FROM="Vendor Management System <no-reply@vms.app>"

# ---- File storage (Cloudinary) ----
# If left blank, uploads are stored on local disk under /uploads instead.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ---- Super Admin seed account (used by prisma/seed.ts) ----
SEED_SUPER_ADMIN_EMAIL=superadmin@vms.app
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
